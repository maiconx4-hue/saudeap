# Gere valores longos e aleatórios para os dois segredos.
SECRET_KEY=
JWT_SECRET_KEY=
JWT_COOKIE_SECURE=true
JWT_ACCESS_TOKEN_HOURS=8

# Banco: use uma URL PostgreSQL em produção ou as variáveis MySQL abaixo.
DATABASE_URL=
DB_HOST=localhost
DB_PORT=3306
DB_NAME=saudeap
DB_USER=
DB_PASSWORD=

# Usadas apenas pelo comando de seed; não inclua esses valores no repositório.
ADMIN_EMAIL=
ADMIN_PASSWORD=
